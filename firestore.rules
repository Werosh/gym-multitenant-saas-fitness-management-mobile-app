rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuthenticated() && userDoc().role == 'super_admin';
    }

    function belongsToGym(gymId) {
      return isAuthenticated() && userDoc().gymId == gymId;
    }

    function isOwner(gymId) {
      return belongsToGym(gymId) && userDoc().role == 'owner';
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        request.auth.uid == userId ||
        (resource.data.gymId != null && belongsToGym(resource.data.gymId))
      );
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (
        request.auth.uid == userId ||
        isSuperAdmin() ||
        (resource.data.gymId != null && isOwner(resource.data.gymId))
      );
      allow delete: if isSuperAdmin() || (
        resource.data.gymId != null && isOwner(resource.data.gymId)
      );
    }

    match /gyms/{gymId} {
      allow read: if isSuperAdmin() || belongsToGym(gymId);
      allow create: if isAuthenticated();
      allow update: if isSuperAdmin() || isOwner(gymId);
      allow delete: if isSuperAdmin();
    }

    match /workouts/{workoutId} {
      allow read: if isSuperAdmin() || belongsToGym(resource.data.gymId);
      allow create: if belongsToGym(request.resource.data.gymId);
      allow update, delete: if belongsToGym(resource.data.gymId);
    }

    match /attendance/{attendanceId} {
      allow read: if isSuperAdmin() || belongsToGym(resource.data.gymId);
      allow create: if belongsToGym(request.resource.data.gymId);
      allow update: if belongsToGym(resource.data.gymId);
    }

    match /memberships/{membershipId} {
      allow read: if isSuperAdmin() || belongsToGym(resource.data.gymId);
      allow create, update: if belongsToGym(request.resource.data.gymId) || belongsToGym(resource.data.gymId);
    }

    match /notifications/{notificationId} {
      allow read: if isSuperAdmin() || (
        belongsToGym(resource.data.gymId) &&
        (userDoc().role == 'owner' || request.auth.uid == resource.data.userId)
      );
      allow create: if belongsToGym(request.resource.data.gymId);
    }
  }
}
